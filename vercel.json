{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/mydarrin-v3.html"
    },
    {
      "source": "/mydarrin-v3",
      "destination": "/mydarrin-v3.html"
    },
    {
      "source": "/mydarrin-v3/",
      "destination": "/mydarrin-v3.html"
    },
    {
      "source": "/index",
      "destination": "/mydarrin-v3.html"
    },
    {
      "source": "/home",
      "destination": "/mydarrin-v3.html"
    },
    {
      "source": "/diagtest",
      "destination": "/mydarrin-categorie-servicii.html?cat=instalatii-electrice"
    },
    {
      "source": "/servicii/:slug",
      "destination": "/mydarrin-categorie-servicii.html?type=servicii&cat=:slug"
    },
    {
      "source": "/materiale/:slug",
      "destination": "/mydarrin-categorie-servicii.html?type=materiale&cat=:slug"
    },
    {
      "source": "/inchiriere/:slug",
      "destination": "/mydarrin-categorie-servicii.html?type=inchiriere&cat=:slug"
    }
  ],
  "redirects": [
    {
      "source": "/mydarrin-v3/",
      "destination": "/mydarrin-v3",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "admin.mydarrin.homebestpal.com" }],
      "destination": "/mydarrin-superadmin.html",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "api.mydarrin.homebestpal.com" }],
      "destination": "/api/health",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(self), payment=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; img-src 'self' data: https: blob:; script-src 'self' 'unsafe-inline' https://esm.sh https://cdn.tailwindcss.com https://cdn.jsdelivr.net https://unpkg.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.tailwindcss.com; font-src 'self' https://fonts.gstatic.com data:; connect-src 'self' https://*.supabase.co https://esm.sh https://cdn.jsdelivr.net https://ipapi.co https://nominatim.openstreetmap.org https://wa.me; frame-ancestors 'self'; base-uri 'self'; form-action 'self'"
        },
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    }
  ]
}